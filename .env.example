# ICU-PAUSE Agents Configuration
# Copy this file to .env and fill in your values

# ── Data paths (required) ───────────────────────────────────────────
# Path to CLIF-formatted Parquet directory (see README for required files)
ICUPAUSE_CLIF_DATA_DIR=/path/to/clif-parquet

# Optional: separate directory for clinical note CSVs
# (defaults to CLIF_DATA_DIR if not set)
ICUPAUSE_NOTES_DATA_DIR=

# ── LLM provider ────────────────────────────────────────────────────
# Options: local (Ollama, default) | openai | anthropic | azure
ICUPAUSE_LLM_PROVIDER=local
ICUPAUSE_LLM_MODEL=qwen2.5:latest

# Local model endpoint (Ollama default shown)
ICUPAUSE_LOCAL_LLM_URL=http://localhost:11434/v1

# ── API keys (only needed for cloud providers) ──────────────────────
ICUPAUSE_ANTHROPIC_API_KEY=
ICUPAUSE_OPENAI_API_KEY=
