# Azure Entra (MSAL) — create an App Registration in NU Azure portal
AZURE_TENANT_ID=your-nu-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-app-registration-secret

# Azure Blob Storage — connection string from Storage Account
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
BLOB_CONTAINER_NAME=icupause-review

# In-app passwords
REVIEW_APP_PASSWORD=study-shared-password
ADMIN_PASSWORD=admin-only-password

# Auth mode: "entra_plus_password" (production) or "password_only" (iterative pilot)
REVIEW_APP_AUTH_MODE=entra_plus_password
